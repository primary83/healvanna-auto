{
  "permissions": {
    "allow": [
      "Bash(npx next:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(while read f)",
      "Bash(do head -6 \"$f\")",
      "Bash(echo \"ALREADY_IMPORTS: $f\")",
      "Bash(done)",
      "Bash(node fix-navs.cjs)",
      "Bash(do grep -l \"HEALVANNA\" \"$f\")",
      "Bash(npm run build)"
    ]
  }
}
